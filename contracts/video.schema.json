{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/video.schema.json",
  "title": "Video job contract payloads",
  "description": "Validation subset for batch video payloads derived from contracts/openapi.yaml and ARCHITECTURE.md examples.",
  "oneOf": [
    {
      "$ref": "#/$defs/PrivacyOptions"
    },
    {
      "$ref": "#/$defs/OutputOptions"
    },
    {
      "$ref": "#/$defs/VideoJobConfig"
    },
    {
      "$ref": "#/$defs/VideoCandidateAnalysisResponse"
    },
    {
      "$ref": "#/$defs/VideoJobCreateResponse"
    },
    {
      "$ref": "#/$defs/JobProgress"
    },
    {
      "$ref": "#/$defs/VideoJobResult"
    },
    {
      "$ref": "#/$defs/VideoJobStatusResponse"
    },
    {
      "$ref": "#/$defs/VideoJobCancelResponse"
    }
  ],
  "$defs": {
    "PrivacyOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blur_faces",
        "blur_plates",
        "blur_text",
        "allowlist_enabled"
      ],
      "properties": {
        "blur_faces": {
          "type": "boolean"
        },
        "blur_plates": {
          "type": "boolean"
        },
        "blur_text": {
          "type": "boolean"
        },
        "allowlist_enabled": {
          "type": "boolean"
        }
      }
    },
    "OutputOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "container",
        "video_codec",
        "keep_audio"
      ],
      "properties": {
        "container": {
          "type": "string",
          "enum": [
            "mp4"
          ]
        },
        "video_codec": {
          "type": "string",
          "enum": [
            "h264"
          ]
        },
        "keep_audio": {
          "type": "boolean"
        }
      }
    },
    "VideoJobConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "privacy_options",
        "output_options"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "video_privacy",
            "blur",
            "preserve",
            "character"
          ]
        },
        "character_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "analysis_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "candidate_actions": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "preserve",
              "character",
              "blur",
              "track"
            ]
          }
        },
        "privacy_options": {
          "$ref": "#/$defs/PrivacyOptions"
        },
        "output_options": {
          "$ref": "#/$defs/OutputOptions"
        }
      }
    },
    "VideoJobCreateData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "status",
        "status_endpoint",
        "cancel_endpoint"
      ],
      "properties": {
        "job_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued"
          ]
        },
        "status_endpoint": {
          "type": "string"
        },
        "cancel_endpoint": {
          "type": "string"
        }
      }
    },
    "VideoJobCreateResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "data",
        "error"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/VideoJobCreateData"
        },
        "error": {
          "type": "null"
        }
      }
    },
    "VideoFaceCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "image_url",
        "frame_index",
        "bbox",
        "confidence"
      ],
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "image_url": {
          "type": "string"
        },
        "frame_index": {
          "type": "integer"
        },
        "bbox": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "confidence": {
          "type": "number"
        }
      }
    },
    "VideoCandidateAnalysisData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "source_filename",
        "candidates"
      ],
      "properties": {
        "analysis_id": {
          "type": "string"
        },
        "source_filename": {
          "type": "string"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VideoFaceCandidate"
          }
        }
      }
    },
    "VideoCandidateAnalysisResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "data",
        "error"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/VideoCandidateAnalysisData"
        },
        "error": {
          "type": "null"
        }
      }
    },
    "JobProgress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "percent",
        "processed_frames",
        "total_frames",
        "eta_sec"
      ],
      "properties": {
        "percent": {
          "type": "integer"
        },
        "processed_frames": {
          "type": "integer"
        },
        "total_frames": {
          "type": "integer"
        },
        "eta_sec": {
          "type": "integer"
        }
      }
    },
    "VideoJobResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "download_url",
        "preview_thumbnail_url",
        "contact_sheet_url",
        "qa_report_json_url",
        "qa_report_markdown_url",
        "qa_summary",
        "expires_at"
      ],
      "properties": {
        "download_url": {
          "type": "string"
        },
        "preview_thumbnail_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "contact_sheet_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "qa_report_json_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "qa_report_markdown_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "qa_summary": {
          "oneOf": [
            {
              "$ref": "#/$defs/VideoQaSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "VideoQaSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "processed_frames",
        "detection_totals",
        "average_blur_reduction_pct",
        "suspect_frame_count"
      ],
      "properties": {
        "processed_frames": {
          "type": "integer"
        },
        "detection_totals": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "average_blur_reduction_pct": {
          "type": [
            "number",
            "null"
          ]
        },
        "suspect_frame_count": {
          "type": "integer"
        }
      }
    },
    "VideoJobStatusData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "status",
        "progress",
        "result"
      ],
      "properties": {
        "job_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "processing",
            "completed",
            "failed",
            "cancelled"
          ]
        },
        "progress": {
          "$ref": "#/$defs/JobProgress"
        },
        "result": {
          "oneOf": [
            {
              "$ref": "#/$defs/VideoJobResult"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "VideoJobStatusResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "data",
        "error"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/VideoJobStatusData"
        },
        "error": {
          "type": "null"
        }
      }
    },
    "VideoJobCancelData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "status"
      ],
      "properties": {
        "job_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "cancelled"
          ]
        }
      }
    },
    "VideoJobCancelResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "data",
        "error"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/VideoJobCancelData"
        },
        "error": {
          "type": "null"
        }
      }
    }
  }
}
