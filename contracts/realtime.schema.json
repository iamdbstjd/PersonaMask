{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/realtime.schema.json",
  "title": "Realtime contract payloads",
  "description": "Validation subset for realtime payloads derived from contracts/openapi.yaml and ARCHITECTURE.md examples.",
  "oneOf": [
    {
      "$ref": "#/$defs/StreamProfile"
    },
    {
      "$ref": "#/$defs/PrivacyOptions"
    },
    {
      "$ref": "#/$defs/RealtimeSessionCreateRequest"
    },
    {
      "$ref": "#/$defs/RealtimeSessionResponse"
    },
    {
      "$ref": "#/$defs/RealtimeSessionDeleteResponse"
    },
    {
      "$ref": "#/$defs/RealtimeFrameMeta"
    },
    {
      "$ref": "#/$defs/XFrameMeta"
    },
    {
      "$ref": "#/$defs/RealtimeFrameJsonData"
    },
    {
      "$ref": "#/$defs/RealtimeFrameJsonResponse"
    }
  ],
  "$defs": {
    "StreamProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_fps",
        "frame_width",
        "jpeg_quality",
        "response_mode"
      ],
      "properties": {
        "target_fps": {
          "type": "integer"
        },
        "frame_width": {
          "type": "integer"
        },
        "jpeg_quality": {
          "type": "number"
        },
        "response_mode": {
          "type": "string",
          "enum": [
            "binary_jpeg",
            "json_base64"
          ]
        }
      }
    },
    "PrivacyOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blur_faces",
        "blur_plates",
        "blur_text",
        "allowlist_enabled"
      ],
      "properties": {
        "blur_faces": {
          "type": "boolean"
        },
        "blur_plates": {
          "type": "boolean"
        },
        "blur_text": {
          "type": "boolean"
        },
        "allowlist_enabled": {
          "type": "boolean"
        }
      }
    },
    "DetectionCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "faces_total",
        "faces_redacted",
        "plates_redacted",
        "text_regions_redacted"
      ],
      "properties": {
        "faces_total": {
          "type": "integer"
        },
        "faces_redacted": {
          "type": "integer"
        },
        "plates_redacted": {
          "type": "integer"
        },
        "text_regions_redacted": {
          "type": "integer"
        }
      }
    },
    "RealtimeSessionCreateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "stream_profile",
        "privacy_options"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "character",
            "privacy"
          ]
        },
        "preset_id": {
          "type": "string"
        },
        "stream_profile": {
          "$ref": "#/$defs/StreamProfile"
        },
        "privacy_options": {
          "$ref": "#/$defs/PrivacyOptions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "character"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "required": [
              "preset_id"
            ]
          }
        }
      ]
    },
    "RealtimeSessionData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "mode",
        "accepted_profile",
        "frame_endpoint",
        "expires_in_sec"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "character",
            "privacy"
          ]
        },
        "accepted_profile": {
          "$ref": "#/$defs/StreamProfile"
        },
        "frame_endpoint": {
          "type": "string"
        },
        "expires_in_sec": {
          "type": "integer"
        }
      }
    },
    "RealtimeSessionResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "data",
        "error"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/RealtimeSessionData"
        },
        "error": {
          "type": "null"
        }
      }
    },
    "RealtimeSessionDeleteData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "closed"
      ],
      "properties": {
        "closed": {
          "type": "boolean"
        }
      }
    },
    "RealtimeSessionDeleteResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "data",
        "error"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/RealtimeSessionDeleteData"
        },
        "error": {
          "type": "null"
        }
      }
    },
    "RealtimeFrameMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "timestamp_ms",
        "client_width",
        "client_height",
        "rotation_deg",
        "mode"
      ],
      "properties": {
        "frame_id": {
          "type": "integer"
        },
        "timestamp_ms": {
          "type": "integer"
        },
        "client_width": {
          "type": "integer"
        },
        "client_height": {
          "type": "integer"
        },
        "rotation_deg": {
          "type": "number"
        },
        "mode": {
          "type": "string",
          "enum": [
            "character",
            "privacy"
          ]
        }
      }
    },
    "PrimaryFace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bbox",
        "preset_id"
      ],
      "properties": {
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          }
        },
        "preset_id": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "XFrameMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "server_latency_ms",
        "detections"
      ],
      "properties": {
        "frame_id": {
          "type": "integer"
        },
        "server_latency_ms": {
          "type": "integer"
        },
        "detections": {
          "$ref": "#/$defs/DetectionCounts"
        },
        "primary_face": {
          "$ref": "#/$defs/PrimaryFace"
        }
      }
    },
    "RealtimeFrameJsonData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "mime_type",
        "processed_image_base64",
        "server_latency_ms",
        "detections"
      ],
      "properties": {
        "frame_id": {
          "type": "integer"
        },
        "mime_type": {
          "type": "string"
        },
        "processed_image_base64": {
          "type": "string"
        },
        "server_latency_ms": {
          "type": "integer"
        },
        "detections": {
          "$ref": "#/$defs/DetectionCounts"
        }
      }
    },
    "RealtimeFrameJsonResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "data",
        "error"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/RealtimeFrameJsonData"
        },
        "error": {
          "type": "null"
        }
      }
    }
  }
}
